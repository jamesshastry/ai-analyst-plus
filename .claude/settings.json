{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "mcp__snowflake__run_snowflake_query",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-snowflake-query.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|Read|NotebookEdit|MultiEdit|Glob|Grep|WebFetch|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/log-action.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
